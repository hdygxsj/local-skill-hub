{
  "$schema": "https://v2.tauri.app/schemas/desktop-schema.json",
  "productName": "Easy Skills",
  "version": "0.1.0",
  "identifier": "com.easy-skills.app",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": "cd ../web && npm run build",
    "devUrl": "http://localhost:27842",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Easy Skills Hub",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "targets": "all",
    "icon": [
      "icons/icon_512x512.png"
    ]
  }
}
