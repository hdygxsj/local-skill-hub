{
  "$schema": "https://v2.tauri.app/schemas/desktop-schema.json",
  "productName": "Easy Skills",
  "version": "0.3.0",
  "identifier": "com.easy-skills.hub",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": "echo 'Web already built via make build'",
    "devUrl": "http://localhost:27842",
    "frontendDist": "./assets/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Easy Skills Hub",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html"
      }
    ]
  },
  "bundle": {
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon_512x512.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "wix": null
    }
  }
}
